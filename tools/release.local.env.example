# ==============================================================================
#  tools/release.local.env.example — Template for tools/release.local.env
#
#  Copy this file to tools/release.local.env and fill in your own values:
#      cp tools/release.local.env.example tools/release.local.env
#
#  tools/release.local.env is git-ignored and must NEVER be committed — it
#  contains your host's FTP credentials. See docs/firmware-updates.md.
# ==============================================================================

# FTPS (explicit FTP-over-TLS) target for the plain-HTTP host the lamp
# actually checks (must be servable at the ${update_manifest_url} configured
# in cloud-lamp.yaml, which should point at this same directory).
#
# Use a dedicated, minimal-privilege FTP user for this if your host supports
# it (KAS: Tools → FTP-Zugänge → create new user), scoped to only the
# cloud-lamp.ddproductions.de folder — not the main webspace account. See
# docs/firmware-updates.md#http-host-upload-setup-one-time.

RELEASE_HTTP_FTP_HOST=""
RELEASE_HTTP_FTP_USER=""
RELEASE_HTTP_FTP_PASSWORD=""

# Remote path, relative to this FTP user's home directory. If the user's home
# is already scoped to the cloud-lamp.ddproductions.de webroot (as above),
# this just mirrors this repo's firmware-dist/cloud-lamp/ layout. Leading and
# trailing slashes matter.
RELEASE_HTTP_FTP_PATH="/firmware-dist/cloud-lamp/"
