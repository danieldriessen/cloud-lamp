# ESPHome build cache
.esphome/

# NOTE: firmware-dist/ is intentionally TRACKED — it's the release history and a
# manual-download fallback. Devices themselves fetch from the plain-HTTP host
# tools/release.sh also publishes to (see docs/firmware-updates.md), not from here.

# macOS
.DS_Store

# Python bytecode (generated when ESPHome loads the custom component)
__pycache__/

# ioBroker VS Code extension cache (auto-downloaded type stubs)
.iobroker/

# Per-device credentials — never commit
secrets.yaml

# Release-machine-only config (HTTP host SSH target) — never commit
tools/release.local.env

# ioBroker VS Code extension config (contains private network address and username)
.iobroker-config.json

# ignore resources folder and all its content
resources/
